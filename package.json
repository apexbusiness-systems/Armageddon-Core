{
  "private": true,
  "workspaces": [
    "armageddon-site",
    "packages/*"
  ],
  "scripts": {
    "validate:shadow": "TARGET_ENV=shadow tsx packages/core/src/sim/runner.ts",
    "postinstall": "npm run build -w @armageddon/shared",
    "certify:armageddon": "npm run build -w @armageddon/shared && npm run build -w armageddon-core && npm run typecheck -w armageddon-core && npm run build -w armageddon-site && npm run lint -w armageddon-site",
    "validate:all": "npm ci && npm run certify:armageddon",
    "check:levels": "node scripts/check-level-integrity.mjs",
    "docs:check": "node scripts/check-docs-drift.mjs && node scripts/check-level-integrity.mjs",
    "test": "npm --prefix packages/core run test && npm --prefix armageddon-site run test",
    "lint": "npm run lint:shared && npm run lint:core && npm run lint:site",
    "typecheck": "npm run typecheck:shared && npm run typecheck:core && npm run typecheck:site",
    "build": "npm run build:shared && npm run build:core && npm run build:site",
    "lint:shared": "npm --prefix packages/shared run lint",
    "lint:core": "npm --prefix packages/core run lint",
    "lint:site": "npm --prefix armageddon-site run lint",
    "typecheck:shared": "npm --prefix packages/shared run typecheck",
    "typecheck:core": "npm --prefix packages/core run typecheck",
    "typecheck:site": "npm --prefix armageddon-site run typecheck",
    "build:shared": "npm --prefix packages/shared run build",
    "build:core": "npm --prefix packages/core run build",
    "build:site": "npm --prefix armageddon-site run build",
    "test:e2e:local": "PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100 npx playwright test -c packages/core/playwright.config.ts",
    "certify:staging-e2e": "npm --prefix armageddon-site run certify:staging-e2e",
    "check:docker-contract": "node scripts/check-docker-build-contract.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^17.4.2",
    "undici": "^7.28.0"
  },
  "overrides": {
    "postcss": "8.5.15",
    "next": {
      "postcss": "8.5.15"
    }
  }
}
