{
  "name": "armageddon-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Armageddon Level 7 Certification Engine - Adversarial AI Testing Microservice",
  "main": "dist/index.js",
  "bin": "./bin/armageddon.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/worker.ts",
    "worker": "tsx src/worker.ts",
    "api": "tsx src/api-server.ts",
    "api:dev": "tsx watch src/api-server.ts",
    "test": "vitest run --exclude \"tests/e2e/**\"",
    "bench": "vitest bench",
    "test:memory": "node --expose-gc --max-old-space-size=512 node_modules/vitest/vitest.mjs run --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@armageddon/shared": "*",
    "@supabase/supabase-js": "^2.108.2",
    "@temporalio/activity": "^1.16.2",
    "@temporalio/client": "^1.16.2",
    "@temporalio/worker": "^1.16.2",
    "@temporalio/workflow": "^1.16.2",
    "commander": "^4.1.1",
    "dotenv": "^17.4.2",
    "pdf-lib": "^1.17.1",
    "uuid": "^14.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.39.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
