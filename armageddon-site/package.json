{
  "name": "armageddon-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "build:cloudflare": "CLOUDFLARE_STATIC_EXPORT=true next build && node ../scripts/copy_intake_static.mjs",
    "validate:production-env": "node ../scripts/validate-armageddon-production-env.mjs",
    "deploy:cloudflare": "npm run build:cloudflare && node ../scripts/deploy_cloudflare_static.mjs"
  },
  "dependencies": {
    "@armageddon/shared": "*",
    "@supabase/supabase-js": "^2.108.2",
    "@temporalio/client": "^1.16.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.300.0",
    "next": "^16.2.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "typescript": "^5.3.0",
    "uuid": "^14.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vitest": "^4.1.0"
  }
