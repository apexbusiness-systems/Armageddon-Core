# ARMAGEDDON MOAT SECRETS
# CLASSIFICATION: TOP SECRET (DO NOT COMMIT)

# Supabase Keys (REQUIRED for kinetic engine)
SUPABASE_URL=https://qhjqselqpkfqjfpuxykb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=insert_your_service_role_key_here

# Temporal Configuration
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=armageddon-level-7

# Simulation Mode
SIM_MODE=true
SANDBOX_TENANT=armageddon-test-local

# Attestation Layer (REQUIRED for stable public-key publishing)
# 32-byte Ed25519 seed in hex, base64, or base64url. If unset, signing keys
# are generated per-process and the /api/attestation/pubkey endpoint returns
# HTTP 503 (fail closed). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ARMAGEDDON_ATTESTATION_SEED=

# Database (Local)
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal

# ─────────────────────────────────────────────────────
# OMNIPORT CONNECTOR — APEX-OmniHub Integration
# ─────────────────────────────────────────────────────
# Master toggle — set false to disable all OmniPort routes (they return 503)
OMNIPORT_ENABLED=false
# API key issued by APEX-OmniHub platform (Settings > Integrations > Armageddon)
OMNIPORT_API_KEY=
# HMAC secret for webhook payload signing (shared with OmniHub)
OMNIPORT_WEBHOOK_SECRET=
# JWT secret for live-fire waiver tokens (generated in OmniHub Live-Fire console)
OMNIPORT_LIVE_FIRE_SECRET=
# OmniHub base URL for telemetry push
OMNIPORT_OMNIHUB_URL=https://app.apexomnihub.icu
